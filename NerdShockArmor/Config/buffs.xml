<configs>
	<append xpath="/buffs">
		<buff name="buffNerdCapacitor" hidden="true" icon_color="0,255,255">
			<stack_type value="ignore"/>
			<duration value="0"/>
			<update_rate value="1"/>
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$NerdShockCharges" operation="set" value="3"/>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$NerdShockRecharge" operation="set" value="30"/>

				<triggered_effect trigger="onOtherAttackedSelf" action="AddBuff" target="other" buff="buffShocked">
					<requirement name="EntityTagCompare" target="other" tags="zombie,animal"/>
					<requirement name="CVarCompare" cvar="$NerdShockCharges" operation="GTE" value="1"/>
				</triggered_effect>
				<triggered_effect trigger="onOtherAttackedSelf" action="ModifyCVar" cvar="$NerdShockCharges" operation="subtract" value="1">
					<requirement name="EntityTagCompare" target="other" tags="zombie,animal"/>
					<requirement name="CVarCompare" cvar="$NerdShockCharges" operation="GTE" value="1"/>
				</triggered_effect>
				<triggered_effect trigger="onOtherAttackedSelf" action="ModifyCVar" cvar="$NerdShockRecharge" operation="set" value="30">
					<requirement name="EntityTagCompare" target="other" tags="zombie,animal"/>
					<requirement name="CVarCompare" cvar="$NerdShockCharges" operation="GTE" value="1"/>
				</triggered_effect>

				<triggered_effect trigger="onOtherAttackedSelf" action="AddBuff" target="other" buff="buffShocked">
					<requirement name="EntityTagCompare" target="other" tags="zombie,animal"/>
					<requirement name="CVarCompare" cvar="$NerdShockCharges" operation="LTE" value="0"/>
					<requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LTE" value="@$nerdShockChance"/>
				</triggered_effect>

				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$NerdShockRecharge" operation="subtract" value="1">
					<requirement name="CVarCompare" cvar="$NerdShockCharges" operation="LT" value="3"/>
				</triggered_effect>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$NerdShockCharges" operation="add" value="1">
					<requirement name="CVarCompare" cvar="$NerdShockCharges" operation="LT" value="3"/>
					<requirement name="CVarCompare" cvar="$NerdShockRecharge" operation="LTE" value="0"/>
				</triggered_effect>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$NerdShockRecharge" operation="set" value="30">
					<requirement name="CVarCompare" cvar="$NerdShockCharges" operation="LT" value="3"/>
					<requirement name="CVarCompare" cvar="$NerdShockRecharge" operation="LTE" value="0"/>
				</triggered_effect>

				<triggered_effect trigger="onSelfBuffRemove" action="RemoveCVar" cvar="$NerdShockCharges,$NerdShockRecharge"/>
			</effect_group>
		</buff>
	</append>
</configs>
